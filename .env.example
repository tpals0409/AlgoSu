# ============================================================
# AlgoSu — 환경변수 예시 파일
# 실제 .env 파일은 절대 Git에 커밋하지 않습니다.
# 이 파일(.env.example)만 커밋합니다.
# ============================================================

# PostgreSQL
POSTGRES_ROOT_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# RabbitMQ
RABBITMQ_USER=algosu
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# Internal API Keys (서비스별 고유 키 — 공유 금지)
INTERNAL_KEY_GATEWAY=change_me_gateway_key
INTERNAL_KEY_SUBMISSION=change_me_submission_key
INTERNAL_KEY_PROBLEM=change_me_problem_key
INTERNAL_KEY_GITHUB_WORKER=change_me_github_worker_key
INTERNAL_KEY_AI_ANALYSIS=change_me_ai_analysis_key

# JWT
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=1h

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=

# Gemini API
GEMINI_API_KEY=

# GitHub OAuth (사용자 개인 레포 연동)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
