# ============================================
# AlgoSu Frontend 환경변수 템플릿
# 복사: cp .env.example .env.local
# ============================================

# --- API ---
# Gateway API base URL (Next.js rewrites 경유)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# --- App ---
# 앱 환경 (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# --- 개발 전용 ---
# true로 설정 시 Mock 데이터 사용 (AuthContext, StudyContext, middleware 우회)
NEXT_PUBLIC_DEV_MOCK=false

# --- MinIO (오브젝트 스토리지) ---
# MinIO 퍼블릭 URL (next.config.ts images.remotePatterns에 사용)
# 로컬: http://localhost:9000  |  운영: https://minio.algosu.kr
NEXT_PUBLIC_MINIO_URL=

# --- 번들 분석 (선택) ---
# true로 설정 시 @next/bundle-analyzer 활성화
# ANALYZE=true
