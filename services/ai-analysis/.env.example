# RabbitMQ
RABBITMQ_URL=amqp://algosu:change_me@localhost:5672

# Redis (Pub/Sub 상태 브로드캐스트)
REDIS_URL=redis://localhost:6379

# Gemini API
GEMINI_API_KEY=change_me

# Submission Service (내부 HTTP)
SUBMISSION_SERVICE_URL=http://submission-service:3003
SUBMISSION_SERVICE_KEY=change_me_submission_key

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30
CB_HALF_OPEN_REQUESTS=2

# Internal API Key
INTERNAL_API_KEY=change_me_ai_analysis_key
