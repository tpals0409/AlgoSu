PORT=3000

# JWT (HS256 고정, none 알고리즘 불허)
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=1h

# Redis (Rate Limit, TTL 필수)
REDIS_URL=redis://localhost:6379

# Identity 서비스 URL
IDENTITY_SERVICE_URL=http://identity-service:3004

# 서비스별 Internal API Key (키 공유 금지, k3s Secret 관리)
INTERNAL_API_KEY=change_me_internal_api_key
INTERNAL_KEY_PROBLEM=change_me_problem_key
INTERNAL_KEY_SUBMISSION=change_me_submission_key
INTERNAL_KEY_AI_ANALYSIS=change_me_ai_analysis_key

# 내부 서비스 URL
PROBLEM_SERVICE_URL=http://problem-service:3002
SUBMISSION_SERVICE_URL=http://submission-service:3003
AI_ANALYSIS_SERVICE_URL=http://ai-analysis-service:8000

# OAuth Callback Base URL (서버 도메인)
OAUTH_CALLBACK_URL=http://localhost:3000

# Frontend URL (OAuth 콜백 후 리다이렉트)
FRONTEND_URL=http://localhost:3001

# CORS
ALLOWED_ORIGINS=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me

# Naver OAuth
NAVER_CLIENT_ID=change_me
NAVER_CLIENT_SECRET=change_me

# Kakao OAuth
KAKAO_CLIENT_ID=change_me
KAKAO_CLIENT_SECRET=change_me

# Admin (쉼표 구분, 피드백 관리 API 접근 제어)
ADMIN_EMAILS=tpals0409dev@gmail.com

# GitHub OAuth (2단계 연동)
GITHUB_CLIENT_ID=change_me
GITHUB_CLIENT_SECRET=change_me
