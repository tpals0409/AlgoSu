# RabbitMQ
RABBITMQ_URL=amqp://algosu:change_me@localhost:5672

# Redis (GitHub App Token 캐시)
REDIS_URL=redis://localhost:6379

# GitHub App (Installation Token — 레포별 동적 발급, 1시간 자동 만료)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
# GITHUB_APP_INSTALLATION_ID 제거됨 — 레포별 동적 조회로 대체

# Gateway Internal API (스터디 github_repo 조회)
GATEWAY_INTERNAL_URL=http://gateway:3000
INTERNAL_KEY_GATEWAY=change_me_gateway_key

# Submission Service (상태 업데이트 콜백)
SUBMISSION_SERVICE_URL=http://submission-service:3003
SUBMISSION_SERVICE_KEY=change_me_submission_key

# GitHub Token 암호화 키 (32바이트 hex, gateway-secrets와 동일)
GITHUB_TOKEN_ENCRYPTION_KEY=

# Problem Service (문제 정보 조회)
PROBLEM_SERVICE_URL=http://problem-service:3002
PROBLEM_SERVICE_KEY=change_me_problem_key

# 메트릭스 서버 포트
METRICS_PORT=9100

# Rate Limit 경고 임계값 (remaining 이 이 값 미만이면 경고)
RATE_LIMIT_WARN_THRESHOLD=10

# GitHub Token 캐시 TTL (초)
GITHUB_TOKEN_TTL=3600

# GitHub Token 갱신 간격 (밀리초)
GITHUB_TOKEN_REFRESH_INTERVAL=3000000

# 재시도 설정
MAX_RETRIES=3
RETRY_DELAY_MS=5000
