PORT=3002

# PostgreSQL (problem_db — problem_user 전용)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=problem_db
DATABASE_USER=problem_user
DATABASE_PASSWORD=change_me

# Redis (마감 시간 캐싱)
REDIS_URL=redis://localhost:6379

# Internal API Key (자신의 키 — 요청 검증용)
INTERNAL_API_KEY=change_me_problem_key

# Dual Write — Phase 3 DB 분리 (off/expand/switch-read)
DUAL_WRITE_MODE=off
NEW_DATABASE_HOST=postgres-problem
NEW_DATABASE_PORT=5432
NEW_DATABASE_NAME=problem_db
NEW_DATABASE_USER=problem_user
NEW_DATABASE_PASSWORD=change_me
