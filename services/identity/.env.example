PORT=3004

# PostgreSQL (identity_db — users, studies, study_members, study_invites)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=identity_db
DATABASE_USER=algosu
DATABASE_PASSWORD=change_me

# PostgreSQL TLS (운영 환경 필수)
# DATABASE_SSL=true
# DATABASE_SSL_CA=<base64-encoded PEM CA 인증서>
#   → k8s Secret: base64 인코딩 후 주입 (예: cat ca.pem | base64 -w0)
#   → 생략 시 Node.js 시스템 CA 번들로 검증 (공인 인증서 환경에 적합)

# Internal API Key (자신의 키 — 요청 검증용)
INTERNAL_API_KEY=change_me_identity_key

# JWT (Gateway와 동일 키 — 토큰 검증용)
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=1h

# GitHub 토큰 암호화 키 (AES-256-GCM, 32바이트 hex = 64자)
# github-worker GITHUB_TOKEN_ENCRYPTION_KEY와 반드시 동일 키 사용
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_TOKEN_ENCRYPTION_KEY=change_me_32byte_hex_key_64chars_long_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
