{
  "name": "algosu-submission-service",
  "version": "1.0.0",
  "description": "AlgoSu Submission Service — 코드 제출 CRUD, Saga Orchestrator, Draft",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "migration:run": "typeorm migration:run -d dist/src/database/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/src/database/data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^10.0.0",
    "amqplib": "^0.10.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0"
  },
  "overrides": {
    "glob@>=10.2.0 <10.5.0": "10.5.0",
    "minimatch@>=9.0.0 <9.0.7": "9.0.7",
    "multer@<=2.0.2": "2.1.1",
    "lodash": "4.17.23",
    "webpack@>=5.49.0 <=5.104.0": "5.105.4",
    "tmp@<=0.2.3": "0.2.5",
    "ajv@>=7.0.0-alpha.0 <=8.17.1": "8.18.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/amqplib": "^0.10.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
